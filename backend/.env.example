# ─── Server ──────────────────────────────────────────────
PORT=4000

# ─── Database (SQLite — single file, no server needed) ────
DATABASE_URL="file:./dev.db"

# ─── JWT secrets (change these in production!) ───────────
JWT_SECRET="change-me-access-secret-please"
JWT_REFRESH_SECRET="change-me-refresh-secret-please"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS=7

# ─── CORS — origin of the frontend (Vite default = 5173) ─
CORS_ORIGIN="http://localhost:5173"

# ─── Uploads ─────────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=20
