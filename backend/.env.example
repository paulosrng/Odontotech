# ─── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database (Supabase Postgres) ────────────────────────
# Runtime uses the TRANSACTION POOLER (port 6543) — required on serverless.
# Get both strings from Supabase → "Connect" → ORMs → Prisma.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations use the DIRECT connection (port 5432).
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─── Supabase Storage (exam files) ───────────────────────
# Supabase → Project Settings → API
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-secret>"   # server-side only, never expose to the browser
SUPABASE_STORAGE_BUCKET="exams"

# ─── JWT secrets (change these in production!) ───────────
JWT_SECRET="change-me-access-secret-please"
JWT_REFRESH_SECRET="change-me-refresh-secret-please"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS=7

# ─── CORS ────────────────────────────────────────────────
# '*' is fine when the frontend is served same-origin (default).
# Otherwise set the frontend origin(s), comma-separated.
CORS_ORIGIN="*"

# ─── Uploads ─────────────────────────────────────────────
MAX_UPLOAD_MB=20
